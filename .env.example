# Phase 5 sub-phase E (2026-05-10): Firebase 의존 일괄 제거.
#   FIREBASE_SERVICE_ACCOUNT_PATH / FIREBASE_DATABASE_URL 제거.
#   audit log는 game_logger 노드 + SQLite append-only DB.
# Phase 5 sub-phase D4: voice 모듈은 2026-05-04 제거됨 — VOICE_INPUT_ENABLED dead key.
# Phase 5: LLM_CHESS_LOGIC_ENABLED / OPENAI_API_KEY 미사용 (stockfish 단일 엔진).

# === Robot Connection (Doosan M0609) ===
# DOOSAN_ROBOT_IP=192.168.137.100
# ROBOT_MODE=virtual            # virtual | real

# === App Config ===
# LOG_LEVEL=INFO
# YOLO_MODEL_PATH=src/cobot2/models/best.pt
# RESNET_MODEL_PATH=src/cobot2/models/resnet18_best.pth
# CHESS_GRID_PATH=src/cobot2/cobot2/chess_grid.json
# CAMERA_SOURCE=3
# STOCKFISH_PATH=/usr/games/stockfish

# === Game Logger (sub-phase E) ===
# 빈 값/미설정이면 기본 ~/.local/share/cobot2_chess_ai/game_log.db 사용.
# SQLite WAL + append-only TRIGGER 강제. 디렉토리 부재 시 자동 생성.
# CHESS_AI_LOG_DB_PATH=

# === Stockfish persistence (sub-phase D3) ===
# 엔진의 castling rights / dict_memory 영속화 위치. 미설정이면 동일 디렉토리 기본값.
# CHESS_AI_STATE_PATH=~/.local/share/cobot2_chess_ai/chess_state.json
