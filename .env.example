# === Firebase ===
# FIREBASE_SERVICE_ACCOUNT_PATH=/abs/path/to/serviceAccountKey.json
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# === LLM API Keys ===
# OPENAI_API_KEY=

# === Robot Connection (Doosan M0609) ===
# DOOSAN_ROBOT_IP=192.168.137.100
# ROBOT_MODE=virtual            # virtual | real

# === Feature Flags (default OFF) ===
# VOICE_INPUT_ENABLED=0
# LLM_CHESS_LOGIC_ENABLED=0

# === App Config ===
# LOG_LEVEL=INFO
# YOLO_MODEL_PATH=src/cobot2/models/best.pt
# STOCKFISH_PATH=/usr/games/stockfish
