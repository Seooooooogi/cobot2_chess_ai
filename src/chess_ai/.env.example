# cobot2_chess_ai — environment template (committed to git)
# Copy to src/chess_ai/.env and fill values. .env is gitignored.
# Phase 5 complete: Firebase dependency removed. voice/OpenAI removed 2026-05-04.

# === Robot Connection (Doosan M0609) ===
DOOSAN_ROBOT_IP=192.168.137.100
ROBOT_MODE=virtual

# === App Config ===
LOG_LEVEL=INFO
# Model paths — after `colcon build`, these files are installed under
# install/chess_ai/share/chess_ai/{train_pt,config}/. .pt weights are gitignored,
# so source them into src/chess_ai/chess_ai/train_pt/ before building.
YOLO_MODEL_PATH=/home/<user>/cobot2_chess_ai/install/chess_ai/share/chess_ai/train_pt/best.pt
RESNET_MODEL_PATH=/home/<user>/cobot2_chess_ai/install/chess_ai/share/chess_ai/train_pt/classifier.pt
CHESS_GRID_PATH=/home/<user>/cobot2_chess_ai/install/chess_ai/share/chess_ai/config/chess_grid.json
CAMERA_SOURCE=3
STOCKFISH_PATH=/usr/games/stockfish
