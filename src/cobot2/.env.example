# cobot2_chess_ai — environment template (committed to git)
# Copy to src/cobot2/.env and fill values. .env is gitignored.
# voice/OpenAI stack removed 2026-05-04

# === Robot Connection (Doosan M0609) ===
DOOSAN_ROBOT_IP=192.168.137.100
ROBOT_MODE=virtual

# === Feature Flags (default OFF) ===
LLM_CHESS_LOGIC_ENABLED=0

# === Firebase ===
# 미설정 시 init_firebase()는 RuntimeError (vision_db, main 모두 lazy init — launch 자체는 PASS).
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccount.json
FIREBASE_DATABASE_URL=https://<project>.asia-southeast1.firebasedatabase.app


# === App Config ===
LOG_LEVEL=INFO
# Model paths — after `colcon build`, these files are installed under
# install/cobot2/share/cobot2/{train_pt,config}/. .pt weights are gitignored,
# so source them into src/cobot2/cobot2/train_pt/ before building.
YOLO_MODEL_PATH=/home/<user>/cobot2_chess_ai/install/cobot2/share/cobot2/train_pt/best.pt
RESNET_MODEL_PATH=/home/<user>/cobot2_chess_ai/install/cobot2/share/cobot2/train_pt/classifier.pt
CHESS_GRID_PATH=/home/<user>/cobot2_chess_ai/install/cobot2/share/cobot2/config/chess_grid.json
CAMERA_SOURCE=3
STOCKFISH_PATH=/usr/games/stockfish
