# cobot2_chess_ai — environment template (committed to git)
# Copy to src/cobot2/.env and fill values. .env is gitignored.

# === Robot Connection (Doosan M0609) ===
DOOSAN_ROBOT_IP=192.168.137.100
ROBOT_MODE=virtual

# === Feature Flags (default OFF) ===
VOICE_INPUT_ENABLED=0
LLM_CHESS_LOGIC_ENABLED=0

# === Firebase (deferred — 로컬 DB 마이그레이션 예정) ===
# FIREBASE_SERVICE_ACCOUNT_PATH 활성화 시: vision_db.py 가 이 경로 사용.
# 미설정 시 init_firebase()는 RuntimeError.
# Firebase DB URL은 vision_db.py 내 하드코딩 (Phase 1+ 마이그레이션 시 env 화 예정).
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccount.json

# === OpenAI (Input Policy: 신규 추가 금지) ===
# 의도적 미설정. 기존 STT/voice_control 코드는 Phase 1+에서 비활성화 예정.
# OPENAI_API_KEY=

# === App Config ===
LOG_LEVEL=INFO
YOLO_MODEL_PATH=src/cobot2/models/best.pt
STOCKFISH_PATH=/usr/games/stockfish
